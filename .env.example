# ──────────────────────────────────────────────────────────────
# Doing Life Today — Environment Variables
# ──────────────────────────────────────────────────────────────
# Set these in Firebase Console → Functions → Configuration,
# or use the Firebase CLI:
#   firebase functions:config:set mailerlite.token="your_token"
#   firebase functions:config:set mailerlite.group_id="your_group_id"
#   firebase functions:config:set mailerlite.contact_group_id="your_contact_group_id"
#
# Then in functions/index.js they are accessed via process.env.*
# ──────────────────────────────────────────────────────────────

# ── MailerLite ────────────────────────────────────────────────
# Get your API token from MailerLite dashboard → Integrations → API
# https://dashboard.mailerlite.com/integrations/api
MAILERLITE_API_TOKEN=your_mailerlite_api_token_here

# Subscriber group ID for newsletter sign-ups (optional but recommended)
# MailerLite → Subscribers → Groups → click your group → copy ID from URL
MAILERLITE_GROUP_ID=your_newsletter_group_id_here

# Subscriber group ID for contact form inquiries (optional but recommended)
# Create a "Contact Inquiries" group in MailerLite and paste its ID here
MAILERLITE_CONTACT_GROUP_ID=your_contact_group_id_here

# ── MailerLite custom fields required for the contact form ─────
# Before using the contact form, create these custom fields in MailerLite:
# Dashboard → Subscribers → Fields → Add custom field
#
#   Field name      Type
#   ────────────    ──────────
#   inquiry_type    Text
#   last_message    Text
#
# The "company" field (for Organization) is a built-in MailerLite field.
